# ==========================================
# H MED DISTRIBUIDORA - Configurações Backend
# ==========================================

# Ambiente
NODE_ENV=production
PORT=3001

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://hmed_user:SUA_SENHA_AQUI@localhost:5432/hmed_db"

# JWT
JWT_SECRET=hmed-super-secret-key-change-in-production-2024
JWT_EXPIRES=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Redis (opcional para cache e filas)
REDIS_URL=redis://localhost:6379

# Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=./uploads

# Logs
LOG_LEVEL=info

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app

# Armazenamento (opcional - S3 compatível)
STORAGE_TYPE=local
AWS_BUCKET=hmed-files
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
